class Solution:
    def minAddToMakeValid(self, s: str) -> int:
        open_count = 0   # unmatched '('
        additions = 0    # needed insertions

        for ch in s:
            if ch == '(':
                open_count += 1
            else:  # ')'
                if open_count > 0:
                    open_count -= 1  # match found
                else:
                    additions += 1   # need '('

        return additions + open_count
